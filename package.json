{
  "name": "fetch-trends",
  "private": true,
  "version": "0.0.0",
  "description": "Local Google Autocomplete research CLI for validating search language around micro-business ideas.",
  "type": "module",
  "bin": {
    "fetch-trends-autocomplete": "./dist/src/cli.js",
    "fetch-trends-db": "./dist/src/db.js",
    "fetch-trends-decide": "./dist/src/decide.js",
    "fetch-trends-diagnose": "./dist/src/diagnose.js",
    "fetch-trends-measurement": "./dist/src/measurement.js",
    "fetch-trends-payment-test": "./dist/src/payment-test.js",
    "fetch-trends-report": "./dist/src/report.js",
    "fetch-trends-revalidate": "./dist/src/revalidate.js",
    "fetch-trends-seo-plan": "./dist/src/seo-plan.js",
    "fetch-trends-validate": "./dist/src/validate.js",
    "fetch-trends-web": "./dist/src/commands/web.js",
    "fetch-trends-worker": "./dist/src/commands/worker.js"
  },
  "scripts": {
    "autocomplete": "tsx src/cli.ts",
    "backlog:check": "tsx scripts/check-backlog.ts",
    "db": "tsx src/db.ts",
    "build": "tsc -p tsconfig.json",
    "decide": "tsx src/decide.ts",
    "diagnose": "tsx src/diagnose.ts",
    "lint": "eslint .",
    "measurement": "tsx src/measurement.ts",
    "package:local": "tsx scripts/package-local.ts",
    "payment-test": "tsx src/payment-test.ts",
    "release:check": "tsx scripts/release-check.ts",
    "report": "tsx src/report.ts",
    "roadmap:check": "tsx scripts/check-roadmap.ts",
    "revalidate": "tsx src/revalidate.ts",
    "seo-plan": "tsx src/seo-plan.ts",
    "test": "vitest --run",
    "test:watch": "vitest",
    "validate": "tsx src/validate.ts",
    "web": "tsx src/commands/web.ts",
    "worker": "tsx src/commands/worker.ts"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "commander": "^14.0.2",
    "playwright": "^1.57.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/node": "^24.10.1",
    "eslint": "^9.39.2",
    "globals": "^16.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.49.0",
    "vitest": "^4.0.16"
  }
}
